#!/usr/bin/env bash
# @describe Run a command inside bwrap with only the CWD and select paths writable.
#
# With no positional arguments, runs "bash" (or a profile's BWRAP_CMD). Any
# positional arguments form the command line to run instead.
#
# A profile is a shell file at ~/.config/bwrap-cwd/<profile>.sh that may set:
#   BWRAP_RW   array of paths to additionally bind read-write
#   BWRAP_DEV  array of device files to bind with --dev-bind (e.g. GPU devices)
#   BWRAP_CMD  array holding the command line to run (default: bash)
# All are optional.
#
# -p/--profile may be given multiple times. Also, any file named .bwrap-cwd
# found by searching from the current directory up to the root is sourced;
# it may set the same BWRAP_RW/BWRAP_DEV/BWRAP_CMD variables as a profile.
# Sources are applied in this order: each --profile in the order given on
# the command line, then each found .bwrap-cwd file starting with the one
# nearest the root and ending with the one nearest the current directory
# (so a .bwrap-cwd file always wins over a --profile, and one nearer the
# current directory wins over one nearer the root). -b/-d options are
# appended last and so take final precedence for the binds they add.
# @option -p --profile* <name>  Profile resolving to ~/.config/bwrap-cwd/<name>.sh (repeatable)
# @option -b --bind* <path>     Extra path to bind read-write (repeatable)
# @option -d --dev-bind* <path> Extra device file to --dev-bind (repeatable)
# @arg cmd*                     Command line to run (default: bash)

set -euo pipefail

config_dir=~/.config/bwrap-cwd

# Source a config file, populating BWRAP_RW, BWRAP_DEV and/or BWRAP_CMD.
# Caller is expected to reset those arrays first; source itself only
# ever assigns them (never appends), matching existing profile files.
_load_config() {
    local file="$1"
    [[ -f "$file" ]] || { echo "bwrap-cwd: no such config file: $file" >&2; exit 1; }
    # shellcheck disable=SC1090
    source "$file"
}

# Find .bwrap-cwd files from $PWD up to /, populating the named array
# (nameref) with results ordered from the root-most match to the
# cwd-most match.
_find_dotfiles() {
    local -n _found="$1"
    _found=()
    local dir="$PWD"
    while true; do
        [[ -f "$dir/.bwrap-cwd" ]] && _found=("$dir/.bwrap-cwd" "${_found[@]}")
        [[ "$dir" == "/" ]] && break
        dir="$(dirname "$dir")"
    done
}

# Build and exec the bwrap invocation given the read-write binds, device binds
# and command.  Arguments are the read-write binds, then "--dev--", then the
# device binds, then "--", then the command line.
_run() {
    local -a binds=() devs=() cmd=()
    while [[ "$1" != "--dev--" ]]; do binds+=("$1"); shift; done
    shift
    while [[ "$1" != "--" ]]; do devs+=("$1"); shift; done
    shift
    cmd=("$@")

    local -a args=(
        --ro-bind / /
        --dev /dev
        --proc /proc
    )
    local p
    for p in "${binds[@]}"; do
        args+=(--bind "$p" "$p")
    done
    for p in "${devs[@]}"; do
        args+=(--dev-bind "$p" "$p")
    done

    exec bwrap "${args[@]}" -- "${cmd[@]}"
}

main() {
    local -a BWRAP_RW=() BWRAP_DEV=() BWRAP_CMD=()
    local -a binds=() devs=() cmd=()

    # Fixed default read-write binds.
    binds=(
        "$PWD"
        /tmp
        ~/.cache
    )
    # Temp dirs from the calling environment, if set.
    [[ -n "${TEMP:-}" ]] && binds+=("$TEMP")
    [[ -n "${TMPDIR:-}" ]] && binds+=("$TMPDIR")

    # 1. Each --profile, in the order given on the command line.
    if [[ -n "${argc_profile[*]:-}" ]]; then
        local name
        for name in "${argc_profile[@]}"; do
            BWRAP_RW=() BWRAP_DEV=() BWRAP_CMD=()
            _load_config "$config_dir/$name.sh"
            binds+=("${BWRAP_RW[@]}")
            devs+=("${BWRAP_DEV[@]}")
            [[ -n "${BWRAP_CMD[*]:-}" ]] && cmd=("${BWRAP_CMD[@]}")
        done
    fi

    # 2. Each .bwrap-cwd file found from $PWD to /, root-most first.
    local -a dotfiles
    _find_dotfiles dotfiles
    local file
    for file in "${dotfiles[@]}"; do
        BWRAP_RW=() BWRAP_DEV=() BWRAP_CMD=()
        _load_config "$file"
        binds+=("${BWRAP_RW[@]}")
        devs+=("${BWRAP_DEV[@]}")
        [[ -n "${BWRAP_CMD[*]:-}" ]] && cmd=("${BWRAP_CMD[@]}")
    done

    # 3. Append -b/-d command line options last.
    [[ -n "${argc_bind[*]:-}" ]] && binds+=("${argc_bind[@]}")
    [[ -n "${argc_dev_bind[*]:-}" ]] && devs+=("${argc_dev_bind[@]}")

    # Command precedence: positional args, then last BWRAP_CMD seen above, then bash.
    if [[ -n "${argc_cmd[*]:-}" ]]; then
        cmd=("${argc_cmd[@]}")
    elif [[ -z "${cmd[*]:-}" ]]; then
        cmd=(bash)
    fi

    _run "${binds[@]}" --dev-- "${devs[@]}" -- "${cmd[@]}"
}

eval "$(argc --argc-eval "$0" "$@")"
